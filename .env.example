# TMDB Base URL (required)
# VITE_TMDB_BASE_URL=https://api.themoviedb.org/3

# This project authenticates using Access Token (Bearer).
# If you prefer to use API Key instead, switch the method in `config/api-client.ts`.
# VITE_TMDB_API_KEY=
# VITE_TMDB_ACCESS_TOKEN=

# Streaming API reference including metadata
# VITE_STREAMING_BASE_URL=https://zeldvorik.ru/apiv3/api.php
